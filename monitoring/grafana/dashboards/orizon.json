{
  "id": null,
  "uid": "insightfin-main",
  "title": "insightfin — Observabilidade",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "core-api — Requisições/s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (method, uri, status) (rate(http_server_requests_seconds_count{job=\"core-api\"}[1m]))",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 }
      }
    },
    {
      "id": 2,
      "title": "core-api — Latência p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"core-api\"}[5m]))) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"core-api\"}[5m]))) * 1000",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "min": 0 }
      }
    },
    {
      "id": 3,
      "title": "ai-service — Análises completadas/h por tipo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (type) (increase(ai_analysis_total{job=\"ai-service\",status=\"completed\"}[1h]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      }
    },
    {
      "id": 4,
      "title": "ai-service — Status das análises (total acumulado)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (status) (ai_analysis_total{job=\"ai-service\"})",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "hinsightfintal",
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "title": "core-api — Heap JVM (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{job=\"core-api\",area=\"heap\"} / 1024 / 1024",
          "legendFormat": "heap usado",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_max_bytes{job=\"core-api\",area=\"heap\"} / 1024 / 1024",
          "legendFormat": "heap máximo",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "MiB", "min": 0 }
      }
    },
    {
      "id": 6,
      "title": "ai-service — Requisições/s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (handler, method, status_code) (rate(http_requests_total{job=\"ai-service\"}[1m]))",
          "legendFormat": "{{method}} {{handler}} {{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 }
      }
    }
  ]
}
