# Azure OpenAI standalone (used by the batch orchestrator)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.services.ai.azure.com/openai/v1
AZURE_OPENAI_KEY=
AZURE_OPENAI_MODEL=gpt-4o-mini

# Azure AI Foundry project (used by the Coach Agent — different resource type)
# Endpoint format: https://<resource>.services.ai.azure.com/api/projects/<project-name>
# Authentication is via DefaultAzureCredential — run `az login` locally, or
# rely on managed identity in Azure Container Apps. The SDK 1.0 does not
# accept AzureKeyCredential, so no API key field here.
AZURE_FOUNDRY_PROJECT_ENDPOINT=
AZURE_FOUNDRY_MODEL=gpt-4.1-mini
# Leave AZURE_FOUNDRY_AGENT_ID empty on first run — a new agent will be provisioned
# and its id printed in the logs. Paste it back here to reuse the agent across runs.
AZURE_FOUNDRY_AGENT_ID=
# Vector store ID for Foundry IQ grounding. Generate by running
# `python -m scripts.setup_foundry_iq` once and pasting the printed id here.
# Empty disables grounding — the coach still works but won't cite the corpus.
AZURE_FOUNDRY_VECTOR_STORE_ID=

# Core-API
CORE_API_URL=http://core-api:8080

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=ai-service

# Operational
MONTHLY_CRON=0 8 1 * *
MAX_LLM_CALLS_PER_DAY=500
ANALYSIS_BATCH_SIZE=10
LLM_TIMEOUT_SECONDS=30
