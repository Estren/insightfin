# Azure AI Foundry — one resource serves both the batch orchestrator (via the
# OpenAI-compatible inference endpoint) and the Coach Agent (via Agent Service).
#
# inference_url is the resource-scoped OpenAI surface, used by the batch:
AZURE_FOUNDRY_INFERENCE_URL=https://<your-resource>.services.ai.azure.com/openai/v1
# API key auth covers the batch's openai SDK calls AND any future code paths
# that prefer keys over DefaultAzureCredential.
AZURE_FOUNDRY_API_KEY=

# project_endpoint is the project-scoped Agents surface, used by the Coach:
# Format: https://<resource>.services.ai.azure.com/api/projects/<project-name>
# Coach auth is DefaultAzureCredential — `az login` locally, managed identity
# in Azure Container Apps. The SDK 1.0 does not accept AzureKeyCredential.
AZURE_FOUNDRY_PROJECT_ENDPOINT=
AZURE_FOUNDRY_MODEL=gpt-4.1-mini
# Leave AZURE_FOUNDRY_AGENT_ID empty on first run — a new agent will be provisioned
# and its id printed in the logs. Paste it back here to reuse the agent across runs.
AZURE_FOUNDRY_AGENT_ID=
# Vector store ID for Foundry IQ grounding. Generate by running
# `python -m scripts.setup_foundry_iq` once and pasting the printed id here.
# Empty disables grounding — the coach still works but won't cite the corpus.
AZURE_FOUNDRY_VECTOR_STORE_ID=

# Core-API
CORE_API_URL=http://core-api:8080

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=ai-service

# Operational
MONTHLY_CRON=0 8 1 * *
MAX_LLM_CALLS_PER_DAY=500
ANALYSIS_BATCH_SIZE=10
LLM_TIMEOUT_SECONDS=30
